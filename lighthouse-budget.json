{
  "ci": {
    "assert": {
      "assertions": {
        "categories:performance":    ["error", { "minScore": 0.90 }],
        "categories:accessibility":  ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo":            ["error", { "minScore": 0.90 }],

        "first-contentful-paint":    ["error", { "maxNumericValue": 1800 }],
        "largest-contentful-paint":  ["error", { "maxNumericValue": 2500 }],
        "total-blocking-time":       ["error", { "maxNumericValue": 300  }],
        "cumulative-layout-shift":   ["error", { "maxNumericValue": 0.10 }],
        "speed-index":               ["error", { "maxNumericValue": 3000 }],
        "interactive":               ["error", { "maxNumericValue": 3500 }],

        "uses-optimized-images":     ["warn",  { "minScore": 0 }],
        "uses-webp-images":          ["warn",  { "minScore": 0 }],
        "render-blocking-resources": ["error", { "minScore": 0 }],
        "unused-javascript":         ["warn",  { "maxNumericValue": 50000 }],
        "unused-css-rules":          ["warn",  { "maxNumericValue": 20000 }]
      }
    }
  }
}
