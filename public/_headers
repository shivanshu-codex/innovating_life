# Lumina — HTTP Cache Headers
# Works with Netlify, Cloudflare Pages, and Vercel (via vercel.json headers)

# Immutable static assets — 1 year, never revalidate
# Content-hash in filename ensures safe invalidation
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Self-hosted fonts — 1 year
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# User-uploaded CDN images — 7 days, can revalidate
/cdn/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# PWA icons — 1 month
/icons/*
  Cache-Control: public, max-age=2592000

# Service worker — no cache (must always be fresh for update detection)
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Manifest — 1 day
/manifest.json
  Cache-Control: public, max-age=86400

# HTML pages — always revalidate + security headers
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Root HTML
/
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
